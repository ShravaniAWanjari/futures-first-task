# Example Environment Configuration
# Copy this file to .env and fill in the values

# Required: API Key for LLM generation
GEMINI_API_KEY="your_api_key_here"

# Environment Settings
APP_ENV="development" # or "production"
LOG_LEVEL="INFO"
DEMO_MODE="false"

# Optional model override (defaults are set in backend config).
EMBEDDING_MODEL="all-MiniLM-L6-v2"

# Paths (defaults to local directories within the project root)
# In Docker, these will resolve correctly automatically.
CHROMA_DB_PATH="chroma"
VISTASTREAM_DB_PATH="databases/vistastream.db"
NEONPLAY_DB_PATH="databases/neonplay.db"
SESSIONS_DB_PATH="databases/sessions.db"
